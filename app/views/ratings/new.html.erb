<div class="flex flex-col w-full h-full">
  <div class="flex flex-col bg-saffron-mango-800 text-saffron-mango-200 text-lg">
    <div class="flex justify-between">
      <%= link_to root_path do %>
        <div class="flex items-center p-3">
        <%= image_tag "house.png", class: "px-2" %>
        <p>Home</p>
        </div>
      <% end %>
      <div class="flex p-3">
        <div class="flex items-center px-1">
          <%= image_tag "rate.png", class: "px-2" %>
          <p>Rate</p>
        </div>
        <%= link_to venues_path do %>
          <div class="flex items-center px-1">
            <%= image_tag "chicken.png", class: "px-2" %>
            <p>Venues</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <div class="flex justify-center text-2xl text-carnation-900 font-semibold m-4">
    <h1>Rate <%= @venue.name %></h1>
  </div>
  <%= form_with model: [@venue, @rating] do |form| %>
    <div class="flex flex-col items-center text-carnation-900" data-controller="ratings">
      <table class="table-fixed items-center">
        <tr data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center my-2">
          <td class="w-full"><%= form.label :chicken_rating, "Chicken", class: "font-semibold mr-2" %></td>
          <td><%= form.hidden_field :chicken_rating, data: { ratings_target: "ratingInput" } %></td>
          <% [1, 2, 3, 4, 5].each do |value| %>
            <td><%= button_tag value.to_s, type: "button", class: "rating-button bg-carnation-200 hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-carnation-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %></td>
          <% end %>
        </tr>
        <tr data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center my-2">
          <td class="w-full"><%= form.label :crumb_rating, "Crumb", class: "font-semibold" %></td>
          <td><%= form.hidden_field :crumb_rating, data: { ratings_target: "ratingInput" } %></td>
          <% [1, 2, 3, 4, 5].each do |value| %>
            <td><%= button_tag value.to_s, type: "button", class: "rating-button bg-carnation-200 hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-carnation-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %></td>
          <% end %>
        </tr>
        <tr data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center my-2">
          <td class="w-full"><%= form.label :topping_rating, "Topping", class: "font-semibold" %></td>
          <td><%= form.hidden_field :topping_rating, data: { ratings_target: "ratingInput" } %></td>
          <% [1, 2, 3, 4, 5].each do |value| %>
            <td><%= button_tag value.to_s, type: "button", class: "rating-button bg-carnation-200 hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-carnation-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %></td>
          <% end %>
        </tr>
        <tr data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center my-2">
          <td class="w-full"><%= form.label :sides_rating, "Sides", class: "font-semibold" %></td>
          <td><%= form.hidden_field :sides_rating, data: { ratings_target: "ratingInput" } %></td>
          <% [1, 2, 3, 4, 5].each do |value| %>
            <td><%= button_tag value.to_s, type: "button", class: "rating-button bg-carnation-200 hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-carnation-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %></td>
          <% end %>
        </tr>
        <tr data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center my-2">
          <td class="w-full"><%= form.label :venue_rating, "Venue", class: "font-semibold" %></td>
          <td><%= form.hidden_field :venue_rating, data: { ratings_target: "ratingInput" } %></td>
          <% [1, 2, 3, 4, 5].each do |value| %>
            <td><%= button_tag value.to_s, type: "button", class: "rating-button bg-carnation-200 hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-carnation-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %></td>
          <% end %>
        </tr>
        <tr data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center my-2">
          <td class="w-full"><%= form.label :total_rating, "Overall", class: "font-bold" %></td>
          <td><%= form.hidden_field :total_rating, data: { ratings_target: "ratingInput" } %></td>
          <% [1, 2, 3, 4, 5].each do |value| %>
            <td><%= button_tag value.to_s, type: "button", class: "rating-button bg-carnation-200 hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-carnation-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %></td>
          <% end %>
        </tr>
      </table>
      <div class="flex items-center my-2">
        <%= form.label :price, "Price $" %>
        <%= form.number_field :price, class: "block w-28 px-2 py-1 ml-1 text-lg text-left bg-carnation-50 border-carnation-300 focus:outline-none focus:ring-carnation-600 focus:border-carnation-800 rounded-md" %>
      </div>
      <div class="flex flex-col items-center my-2">
        <%= form.label :comment %>
        <%= form.text_area :comment, size: "70x3", class: "block w-3/4 px-2 py-1 text-lg text-left bg-carnation-50 border-carnation-300 focus:outline-none focus:ring-carnation-600 focus:border-carnation-800 rounded-md" %>
      </div>
      <div>
        <%= form.submit "Submit rating", class: "bg-carnation-200 hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-3 my-4 border border-carnation-500 hover:border-transparent rounded" %>
      </div>
    </div>
  <% end %>
</div>
