<div class="flex flex-col w-full h-full">
  <div class="flex flex-col bg-akaroa-800 text-akaroa-100 text-lg">
    <div class="flex justify-between">
      <%= link_to root_path do %>
        <div class="flex items-center p-3">
        <%= image_tag "house.png", class: "px-2" %>
        <p>Home</p>
        </div>
      <% end %>
      <div class="flex p-3">
        <div class="flex items-center px-1">
          <%= image_tag "rate.png", class: "px-2" %>
          <p>Rate</p>
        </div>
        <%= link_to venues_path do %>
          <div class="flex items-center px-1">
            <%= image_tag "chicken.png", class: "px-2" %>
            <p>Venues</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <div class="flex text-2xl text-akaroa-900 font-semibold m-4">
    <h1>Rate</h1>
  </div>
  <div class="flex flex-col mx-4 text-akaroa-900" data-controller="ratings">
  <%= form_with model: [@venue, @rating] do |form| %>
    <div class="ml-2 mr-40">
      <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
        <%= form.label :chicken_rating, "Chicken", class: "font-semibold" %>
        <%= form.hidden_field :chicken_rating, data: { ratings_target: "ratingInput" } %>
        <div class="flex my-2">
          <% [1, 2, 3, 4, 5].each do |value| %>
            <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
          <% end %>
        </div>
      </div>
      <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
        <%= form.label :crumb_rating, "Crumb", class: "font-semibold" %>
        <%= form.hidden_field :crumb_rating, data: { ratings_target: "ratingInput" } %>
        <div class="flex my-2">
          <% [1, 2, 3, 4, 5].each do |value| %>
            <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
          <% end %>
        </div>
      </div>
      <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
        <%= form.label :topping_rating, "Topping", class: "font-semibold" %>
        <%= form.hidden_field :topping_rating, data: { ratings_target: "ratingInput" } %>
        <div class="flex my-2">
          <% [1, 2, 3, 4, 5].each do |value| %>
            <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
          <% end %>
        </div>
      </div>
      <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
        <%= form.label :sides_rating, "Sides", class: "font-semibold" %>
        <%= form.hidden_field :sides_rating, data: { ratings_target: "ratingInput" } %>
        <div class="flex my-2">
          <% [1, 2, 3, 4, 5].each do |value| %>
            <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
          <% end %>
        </div>
      </div>
      <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
        <%= form.label :venue_rating, "Venue", class: "font-semibold" %>
        <%= form.hidden_field :venue_rating, data: { ratings_target: "ratingInput" } %>
        <div class="flex my-2">
          <% [1, 2, 3, 4, 5].each do |value| %>
            <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
          <% end %>
        </div>
      </div>
      <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
        <%= form.label :total_rating, "Overall", class: "font-bold" %>
        <%= form.hidden_field :total_rating, data: { ratings_target: "ratingInput" } %>
        <div class="flex my-2">
          <% [1, 2, 3, 4, 5].each do |value| %>
            <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
          <% end %>
        </div>
      </div>
    </div>
    <div class="flex items-center  my-2">
      <%= form.label :price, "Price $" %>
      <%= form.number_field :price, class: "block w-60 px-2 py-1 ml-1 text-lg text-left bg-akaroa-50 border-akaroa-300 focus:outline-none focus:ring-akaroa-600 focus:border-akaroa-800 rounded-md" %>
    </div>
    <div class="flex flex-col my-2">
      <%= form.label :comment %>
      <%= form.text_area :comment, size: "70x3", class: "block w-full px-2 py-1 text-lg text-left bg-akaroa-50 border-akaroa-300 focus:outline-none focus:ring-akaroa-600 focus:border-akaroa-800 rounded-md" %>
    </div>
    <div>
      <%= form.submit "Submit rating", class: "bg-akaroa-200 hover:bg-akaroa-500 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 ml-8 mr-2 my-4 border border-akaroa-500 hover:border-transparent rounded" %>
    </div>
  <% end %>
</div>

</div>
