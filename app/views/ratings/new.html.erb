<div class="flex flex-col w-full h-full">
  <div class="flex flex-col bg-akaroa-800 text-akaroa-100 text-lg">
    <div class="flex justify-between">
      <%= link_to root_path do %>
        <div class="flex items-center p-3">
        <%= image_tag "house.png", class: "px-2" %>
        <p>Home</p>
        </div>
      <% end %>
      <div class="flex p-3">
        <div class="flex items-center px-1">
          <%= image_tag "rate.png", class: "px-2" %>
          <p>Rate</p>
        </div>
        <%= link_to venues_path do %>
          <div class="flex items-center px-1">
            <%= image_tag "chicken.png", class: "px-2" %>
            <p>Venues</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <div class="my-2 mx-4" data-controller="ratings">
  <%= form_with model: [@venue, @rating] do |form| %>
    <div class="flex flex-col">
      <div class="mx-8">
        <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
          <%= form.label :chicken_rating, "Chicken" %>
          <%= form.hidden_field :chicken_rating, data: { ratings_target: "ratingInput" } %>
          <div class="flex my-2">
            <% [1, 2, 3, 4, 5].each do |value| %>
              <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 focus:bg-akaroa-400 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
            <% end %>
          </div>
        </div>
        <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
          <%= form.label :crumb_rating, "Crumb" %>
          <%= form.hidden_field :crumb_rating, data: { ratings_target: "ratingInput" } %>
          <div class="flex my-2">
            <% [1, 2, 3, 4, 5].each do |value| %>
              <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 focus:bg-akaroa-400 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
            <% end %>
          </div>
        </div>
        <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
          <%= form.label :topping_rating, "Topping" %>
          <%= form.hidden_field :topping_rating, data: { ratings_target: "ratingInput" } %>
          <div class="flex my-2">
            <% [1, 2, 3, 4, 5].each do |value| %>
              <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 focus:bg-akaroa-400 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
            <% end %>
          </div>
        </div>
        <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
          <%= form.label :sides_rating, "Sides" %>
          <%= form.hidden_field :sides_rating, data: { ratings_target: "ratingInput" } %>
          <div class="flex my-2">
            <% [1, 2, 3, 4, 5].each do |value| %>
              <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 focus:bg-akaroa-400 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
            <% end %>
          </div>
        </div>
        <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
          <%= form.label :venue_rating, "Venue" %>
          <%= form.hidden_field :venue_rating, data: { ratings_target: "ratingInput" } %>
          <div class="flex my-2">
            <% [1, 2, 3, 4, 5].each do |value| %>
              <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 focus:bg-akaroa-400 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
            <% end %>
          </div>
        </div>
        <div data-ratings-target="ratingGroup" class="rating-group flex justify-between items-center">
          <%= form.label :total_rating, "Overall" %>
          <%= form.hidden_field :total_rating, data: { ratings_target: "ratingInput" } %>
          <div class="flex my-2">
            <% [1, 2, 3, 4, 5].each do |value| %>
              <%= button_tag value.to_s, type: "button", class: "rating-button bg-akaroa-200 hover:bg-akaroa-500 focus:bg-akaroa-400 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded", data: { action: "click->ratings#setRating", value: value } %>
            <% end %>
          </div>
        </div>
      </div>
      <div class="flex flex-col">
        <%= form.label :comment %>
        <%= form.text_field :comment %>
      </div>
      <div class="flex flex-col">
        <%= form.label :price, "Price $" %>
        <%= form.number_field :price %>
      </div>
      <div>
        <%= form.submit "Submit rating", class: "bg-akaroa-200 hover:bg-akaroa-500 text-akaroa-700 text-lg font-semibold hover:text-white py-1 px-3 mr-2 border border-akaroa-500 hover:border-transparent rounded" %>
      </div>
    </div>
  <% end %>
</div>

</div>
