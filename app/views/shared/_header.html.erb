  <div class="flex flex-col bg-lavender-gray-900">
    <div class="flex justify-between items-center">
      <%= link_to root_path do %>
        <div class="flex items-center p-3">
        <%= image_tag "house.png", size: "32x32", class: "px-2" %>
        <p class="transition ease-in-out duration-300 text-lavender-gray-200 hover:text-lavender-gray-400 text-lg">Home</p>
        </div>
      <% end %>
      <div class="flex p-3">
        <div class="flex items-center px-1">
          <%= image_tag "rate.png", size: "35x35", class: "px-2" %>
          <p class="transition ease-in-out duration-300 text-lavender-gray-200 hover:text-lavender-gray-400 text-lg">Rate</p>
        </div>
        <%= link_to venues_path do %>
          <div class="flex items-center px-1">
            <%= image_tag "chicken.png", size: "35x35", class: "px-2" %>
            <p class="transition ease-in-out duration-300 text-lavender-gray-200 hover:text-lavender-gray-400 text-lg">Venues</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
