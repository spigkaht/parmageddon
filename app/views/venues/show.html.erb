<div class="flex flex-col w-full h-full" data-controller="venue-details">
  <div class="flex flex-col bg-saffon-mango-800 text-saffon-mango-200 text-lg">
    <div class="flex justify-between">
      <%= link_to root_path do %>
        <div class="flex items-center p-3">
        <%= image_tag "house.png", class: "px-2" %>
        <p>Home</p>
        </div>
      <% end %>
      <div class="flex p-3">
        <%= link_to new_venue_rating_path(@venue) do %>
          <div class="flex items-center px-1">
            <%= image_tag "rate.png", class: "px-2" %>
            <p>Rate</p>
          </div>
        <% end %>
        <%= link_to venues_path do %>
          <div class="flex items-center px-1">
            <%= image_tag "chicken.png", class: "px-2" %>
            <p>Venues</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <div class="h-full flex flex-col font-['Open_Sans'] text-carnation-900 px-2">
    <div class="py-2">
      <h1 class="text-2xl font-semibold"><%= @venue.name %></h1>
      <div class="w-1/4 h-1 py-2 ml-2 border-b-2 border-carnation-950"></div>
    </div>
    <div class="flex flex-col" data-venue-details-target="ratingsDiv">
      <ul class="flex flex-col items-end text-2xl py-1 mt-4">
        <li class="flex justify-end items-center border-b border-carnation-950 w-48 pb-2">
          <p class="font-bold">MEAT</p>
          <span class="material-symbols-sharp !font-bold !text-3xl ml-2 mr-5">
            star
          </span>
          <%= @venue.chicken_rating_average %>
        </li>
        <li class="flex justify-end items-center border-b border-carnation-950 w-48 py-2">
          <p class="font-bold">CRUMB</p>
          <span class="material-symbols-sharp !font-bold !text-3xl ml-2 mr-5">
            star
          </span>
          <%= @venue.crumb_rating_average %>
        </li>
        <li class="flex justify-end items-center border-b border-carnation-950 w-48 py-2">
          <p class="font-bold">TOPPING</p>
          <span class="material-symbols-sharp !font-bold !text-3xl ml-2 mr-5">
            star
          </span>
          <%= @venue.topping_rating_average %>
        </li>
        <li class="flex justify-end items-center border-b border-carnation-950 w-48 py-2">
          <p class="font-bold">SIDES</p>
          <span class="material-symbols-sharp !font-bold !text-3xl ml-2 mr-5">
            star
          </span>
          <%= @venue.sides_rating_average %>
        </li>
        <li class="flex justify-end items-center w-48 pt-2">
          <p class="font-bold">VENUE</p>
          <span class="material-symbols-sharp !font-bold !text-3xl ml-2 mr-5">
            star
          </span>
          <%= @venue.venue_rating_average %>
        </li>
      </ul>
      <div class="flex items-center text-2xl border-y border-carnation-950 mt-6 pl-2 pb-2 pt-2">
        <p>
          <p class="font-bold">TOTAL</p>
          <span class="material-symbols-sharp !font-bold !text-3xl ml-2 mr-5">
            star
          </span>
          <%= "0.0" ? "Not rated" : @venue.total_rating_average %></strong>
        </p>
      </div>
    </div>
    <div class="hidden flex-col ml-2 mt-4" data-venue-details-target="detailsDiv">
      <p><%= @venue.address %></p>
      <p><%= @venue.phone %></p>
      <%= link_to "#{@venue.website}", @venue.website, class: "text-carnation-800" %>
      <h4 class="mt-3">Opening hours</h4>
      <% if @venue.hours %>
        <% JSON.parse(@venue.hours).each do |hours| %>
          <p><%= hours %></p>
        <% end %>
      <% else %>
        <p>Not provided</p>
      <% end %>
    </div>
    <div class="flex justify-between mt-auto py-3 mx-4">
      <%= link_to "Submit Rating", new_venue_rating_path(@venue), class: "bg-transparent hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-2 mr-2 border border-carnation-500 hover:border-transparent rounded" %>
      <div class="flex justify-between ml-3">
        <%= button_tag "Ratings", type: "button", class: "bg-carnation-200 hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-2 mr-2 border border-carnation-500 hover:border-transparent rounded", data: { action: "click->venue-details#showRatingsDiv", venue_details_target: "ratingsButton" } %>
        <%= button_tag "Details", type: "button", class: "bg-transparent hover:bg-carnation-500 text-carnation-700 text-lg font-semibold hover:text-white py-1 px-2 mr-2 border border-carnation-500 hover:border-transparent rounded", data: { action: "click->venue-details#showDetailsDiv", venue_details_target: "detailsButton" } %>
      </div>
    </div>
  </div>
  <div class="w-full h-2/3 flex flex-col relative" data-controller="google-maps">
    <%= button_tag "Search here", class: "bg-transparent z-50 absolute top-2 left-2 hover:bg-carnation-500 text-carnation-700 text-sm font-semibold hover:text-white py-1 px-2 mr-2 border border-carnation-500 hover:border-transparent rounded", data: { action: "click->google-maps#centerMap" } %>
    <div class="loader-venue" data-google-maps-target="loaderDiv"></div>
    <div id="map" class="flex justify-center items-center w-full h-full opacity-50" data-google-maps-target="mapDiv"></div>
  </div>
</div>
